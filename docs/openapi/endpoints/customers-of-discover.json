{
  "endpoint": "/run/companies/gemini/customers-of/discover",
  "method": "POST",
  "summary": "Discover customers of a company using Gemini",
  "description": "Wrapper for Modal function: get_customers_of",
  "request": {
    "schema": "GetCustomersOfRequest",
    "properties": {
      "company_name": {
        "type": "string",
        "required": true
      },
      "domain": {
        "type": "string",
        "required": true
      }
    }
  },
  "response": {
    "schema": "GetCustomersOfResponse",
    "properties": {
      "success": { "type": "boolean", "required": true },
      "domain": { "type": "string | null" },
      "company_name": { "type": "string | null" },
      "customers": { "type": "array of objects | null" },
      "customer_count": { "type": "integer | null" },
      "input_tokens": { "type": "integer | null" },
      "output_tokens": { "type": "integer | null" },
      "cost_usd": { "type": "number | null" },
      "error": { "type": "string | null" }
    }
  },
  "example_request": {
    "company_name": "Salesforce",
    "domain": "salesforce.com"
  }
}
