{
  "endpoint": "/run/companies/gemini/icp-job-titles/research",
  "method": "POST",
  "summary": "Research ICP job titles using Gemini",
  "description": "Wrapper for Modal function: gemini_icp_job_titles",
  "request": {
    "schema": "GeminiICPJobTitlesRequest",
    "properties": {
      "company_name": {
        "type": "string",
        "required": true
      },
      "domain": {
        "type": "string",
        "required": true
      },
      "company_description": {
        "type": "string | null",
        "required": false
      }
    }
  },
  "response": {
    "schema": "GeminiICPJobTitlesResponse",
    "properties": {
      "success": { "type": "boolean", "required": true },
      "domain": { "type": "string | null" },
      "company_name": { "type": "string | null" },
      "inferred_product": { "type": "string | null" },
      "buyer_persona": { "type": "string | null" },
      "titles": { "type": "array of objects | null" },
      "champion_titles": { "type": "array of strings | null" },
      "evaluator_titles": { "type": "array of strings | null" },
      "decision_maker_titles": { "type": "array of strings | null" },
      "input_tokens": { "type": "integer | null" },
      "output_tokens": { "type": "integer | null" },
      "cost_usd": { "type": "number | null" },
      "error": { "type": "string | null" }
    }
  },
  "example_request": {
    "company_name": "Salesforce",
    "domain": "salesforce.com",
    "company_description": "CRM and enterprise cloud software"
  }
}
